# All values are optional and have sensible defaults baked in.
# Copy this file to .env.local to override any of them.

# How long to wait on a single council request before giving up (milliseconds).
REQUEST_TIMEOUT_MS=30000

# Most applications already include a postcode. For the ones that don't, the app
# looks them up from the address. This caps how many lookups run per search so a
# big result set can't hang on the rate-limited geocoder.
POSTCODE_LOOKUP_MAX=50

# Search results are cached in memory so repeat searches return instantly.
CACHE_TTL_MS=300000
CACHE_MAX_ENTRIES=20
